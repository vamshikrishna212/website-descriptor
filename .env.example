# Copy this file to .env and fill in your values
# cp .env.example .env

# ── OpenAI (set if using OpenAI as provider) ──────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ── Ollama (set if using Ollama as provider) ──────────────────────────────────
# Base URL for Ollama's OpenAI-compatible API (default shown below)
OLLAMA_BASE_URL=http://localhost:11434/v1
# Model name as shown in 'ollama list' (e.g. gemma3:270m, llama3.2, mistral)
OLLAMA_MODEL=gemma3:270m
